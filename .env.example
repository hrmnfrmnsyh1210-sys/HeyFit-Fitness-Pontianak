# ─── Database ─────────────────────────────────────────────────
# App pakai MySQL (TiDB Cloud ATAU MySQL lokal lewat XAMPP/Laragon).
#
# PILIHAN A — MySQL LOKAL (phpMyAdmin / XAMPP / Laragon):
#   Import dulu server/database/heyfit-local.sql lewat phpMyAdmin,
#   lalu pakai konfigurasi di bawah ini (TIDB_SSL=false wajib).
TIDB_HOST=127.0.0.1
TIDB_PORT=3306
TIDB_USER=root
TIDB_PASSWORD=
TIDB_DATABASE=heyfit
TIDB_SSL=false
#
# PILIHAN B — TiDB Cloud:
#   Ambil dari TiDB Cloud Console > cluster > tombol "Connect" (General).
#   Hapus baris TIDB_SSL atau set TIDB_SSL=true (default = pakai TLS).
# TIDB_HOST=gateway01.xxxxxx.prod.aws.tidbcloud.com
# TIDB_PORT=4000
# TIDB_USER=xxxxxxxxxxxxxxx.root
# TIDB_PASSWORD=
# TIDB_DATABASE=heyfit

# ─── Session (nuxt-auth-utils) ────────────────────────────────
# String acak minimal 32 karakter untuk enkripsi cookie session.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NUXT_SESSION_PASSWORD=
